{
  "exec": "next dev --turbopack",
  "watch": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    "prisma/schema.prisma",
    "next.config.ts",
    "package.json"
  ],
  "ignore": [
    ".next/**/*",
    "node_modules/**/*",
    ".git/**/*",
    "public/**/*"
  ],
  "ext": "ts,tsx,js,jsx,json,prisma",
  "delay": 1000
} 