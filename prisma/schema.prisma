// 내용 관리 테이블
model G5Content {
  co_id               String  @id @db.VarChar(20)
  co_html             Int     @default(0) @db.TinyInt
  co_subject          String  @default("") @db.VarChar(255)
  co_content          String  @db.LongText
  co_seo_title        String  @default("") @db.VarChar(255)
  co_mobile_content   String  @db.LongText
  co_skin             String  @default("") @db.VarChar(255)
  co_mobile_skin      String  @default("") @db.VarChar(255)
  co_tag_filter_use   Int     @default(0) @db.TinyInt
