// 게시판 파일 테이블
model G5BoardFile {
  bo_table    String   @db.VarChar(20)
  wr_id       Int      @default(0)
  bf_no       Int      @default(0)
  bf_source   String   @default("") @db.VarChar(255)
  bf_file     String   @default("") @db.VarChar(255)
  bf_download Int
  bf_content  String   @db.Text
  bf_fileurl  String   @default("") @db.VarChar(255)
  bf_thumburl String   @default("") @db.VarChar(255)
  bf_storage  String   @default("") @db.VarChar(50)
  bf_filesize Int      @default(0)
  bf_width    Int      @default(0)
  bf_height   Int      @default(0) @db.SmallInt
  bf_type     Int      @default(0) @db.TinyInt
  bf_datetime DateTime @default(dbgenerated("'0000-00-00 00:00:00'"))

  @@id([bo_table, wr_id, bf_no])
  @@map("g5_board_file")
}

// 게시판 추천 테이블
model G5BoardGood {
  bg_id       Int      @id @default(autoincrement())
  bo_table    String   @default("") @db.VarChar(20)
  wr_id       Int      @default(0)
  mb_id       String   @default("") @db.VarChar(20)
  bg_flag     String   @default("") @db.VarChar(255)
  bg_datetime DateTime @default(dbgenerated("'0000-00-00 00:00:00'"))

  @@unique([bo_table, wr_id, mb_id], map: "fkey1")
  @@map("g5_board_good")
}

// 게시판 새글 테이블
model G5BoardNew {
  bn_id       Int      @id @default(autoincrement())
  bo_table    String   @default("") @db.VarChar(20)
  wr_id       Int      @default(0)
  wr_parent   Int      @default(0)
  bn_datetime DateTime @default(dbgenerated("'0000-00-00 00:00:00'"))
  mb_id       String   @default("") @db.VarChar(20)

  @@index([mb_id])
  @@map("g5_board_new")
}

// 인증 내역 테이블
model G5CertHistory {
  cr_id      Int      @id @default(autoincrement())
  mb_id      String   @default("") @db.VarChar(20)
  cr_company String   @default("") @db.VarChar(255)
  cr_method  String   @default("") @db.VarChar(255)
  cr_ip      String   @default("") @db.VarChar(255)
  cr_date    DateTime @default(dbgenerated("'0000-00-00'")) @db.Date
  cr_time    DateTime @default(dbgenerated("'00:00:00'")) @db.Time

  @@index([mb_id])
  @@map("g5_cert_history")
}

