}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Auth 테이블
model G5Auth {
  mb_id   String @db.VarChar(20)
  au_menu String @db.VarChar(50)
  au_auth String @db.VarChar(255) // set을 String으로

  @@id([mb_id, au_menu])
  @@map("g5_auth")
}

// Autosave 테이블
model G5Autosave {
  as_id       Int      @id @default(autoincrement())
  mb_id       String   @db.VarChar(20)
  as_uid      BigInt   @unique @db.UnsignedBigInt
  as_subject  String   @db.VarChar(255)
  as_content  String   @db.Text
  as_datetime DateTime

  @@index([mb_id])
  @@map("g5_autosave")
}

